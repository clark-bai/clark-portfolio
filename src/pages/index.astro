---
import Base from '../layouts/Base.astro';
---

<Base title="Clark — Portfolio">
  <section class="hero">
    <h1 class="hero__name">Clark</h1>
    <p class="hero__tagline">
      Computer science graduate · bioinformatics · machine learning
    </p>
    <div class="hero__cta">
      <a href="/projects" class="btn btn--primary">View Projects</a>
      <a href="/contact" class="btn btn--ghost">Get in Touch</a>
    </div>
  </section>
</Base>

<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var el = document.querySelector('.hero__tagline');
    if (!el) return;

    var text = el.textContent.trim();
    el.textContent = '';
    el.classList.add('hero__tagline--typing');

    var i = 0;
    var speed = 45;

    function type() {
      if (i < text.length) {
        el.textContent += text.charAt(i);
        i++;
        setTimeout(type, speed);
      } else {
        el.classList.remove('hero__tagline--typing');
        el.classList.add('hero__tagline--done');
      }
    }

    type();
  })();
</script>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100dvh - var(--nav-height));
    padding: var(--space-8) var(--space-4);
    margin-top: var(--nav-height);
    position: relative;
    isolation: isolate;

    --hero-grad-1: rgba(37, 99, 235, 0.05);
    --hero-grad-2: rgba(37, 99, 235, 0.08);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 30% 40%, var(--hero-grad-1), transparent),
      radial-gradient(ellipse 60% 80% at 70% 60%, var(--hero-grad-2), transparent);
    background-size: 200% 200%;
    animation: hero-bg-drift 20s ease-in-out infinite alternate;
  }

  .hero__name {
    font-size: clamp(2.5rem, 6vw, 4rem);
    letter-spacing: -0.02em;
  }

  .hero__tagline {
    margin-top: var(--space-4);
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: var(--measure);
    min-height: 1.7em;
  }

  .hero__tagline:global(.hero__tagline--typing)::after {
    content: '|';
    display: inline-block;
    color: var(--color-accent);
    animation: blink 0.7s step-end infinite;
    margin-left: 2px;
    font-weight: var(--font-weight-normal);
  }

  .hero__tagline:global(.hero__tagline--done)::after {
    content: none;
  }

  .hero__cta {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-8);
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-block;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s;
  }

  .btn--primary {
    background-color: var(--color-accent);
    color: #ffffff;
  }

  .btn--primary:hover {
    background-color: var(--color-accent-hover);
    color: #ffffff;
    text-decoration: none;
  }

  .btn--ghost {
    border: 1px solid var(--color-border);
    color: var(--color-text);
    background: transparent;
  }

  .btn--ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    text-decoration: none;
  }

  @keyframes hero-bg-drift {
    0%   { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  /* Dark mode overrides for gradient */
  @media (prefers-color-scheme: dark) {
    .hero:not(:global([data-theme='light']) .hero) {
      --hero-grad-1: rgba(59, 130, 246, 0.06);
      --hero-grad-2: rgba(59, 130, 246, 0.10);
    }
  }

  :global([data-theme='dark']) .hero {
    --hero-grad-1: rgba(59, 130, 246, 0.06);
    --hero-grad-2: rgba(59, 130, 246, 0.10);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero::before {
      animation: none;
    }

    .hero__tagline:global(.hero__tagline--typing)::after {
      animation: none;
      content: none;
    }
  }
</style>
